{
  "$id": "personas.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoSAI-RM Persona Schema",
  "description": "Schema for validating YAML-based persona definition",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "description": { "$ref": "riskmap.schema.json#/definitions/utils/prose-strict" },
    "personas": {
      "type": "array",
      "items": { "$ref": "#/definitions/persona" }
    }
  },
  "required": ["title", "description", "personas"],
  "definitions": {
    "persona": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "personaModelProvider",
            "personaDataProvider",
            "personaPlatformProvider",
            "personaModelServing",
            "personaAgenticProvider",
            "personaApplicationDeveloper",
            "personaGovernance",
            "personaEndUser",
            "personaModelCreator",
            "personaModelConsumer"
          ]
        },
        "title": { "type": "string" },
        "description": { "$ref": "riskmap.schema.json#/definitions/utils/prose-strict" },
        "deprecated": {
          "type": "boolean",
          "description": "Indicates if this persona is deprecated and superseded by newer personas",
          "default": false
        },
        "mappings": {
          "type": "object",
          "description": "Per ADR-021 D5 + ADR-027 D3a/D7 (#343): all six framework keys strictly wired to framework-mapping-patterns-pinned; additionalProperties:false closes the legacy catch-all.",
          "propertyNames": {
            "$ref": "frameworks.schema.json#/definitions/framework/properties/id"
          },
          "properties": {
            "mitre-atlas": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns-pinned/properties/mitre-atlas" }
            },
            "nist-ai-rmf": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns-pinned/properties/nist-ai-rmf" }
            },
            "stride": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns-pinned/properties/stride" }
            },
            "owasp-top10-llm": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns-pinned/properties/owasp-top10-llm" }
            },
            "iso-22989": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns-pinned/properties/iso-22989" }
            },
            "eu-ai-act": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns-pinned/properties/eu-ai-act" }
            }
          },
          "additionalProperties": false,
          "examples": [
            {
              "iso-22989": ["AI Producer@2022"]
            }
          ]
        },
        "responsibilities": {
          "type": "array",
          "description": "List of security control responsibilities for this persona",
          "items": { "type": "string", "minLength": 1 }
        },
        "identificationQuestions": {
          "type": "array",
          "description": "Questions to help identify if this persona applies",
          "items": { "type": "string", "minLength": 1 }
        },
        "externalReferences": {
          "$ref": "external-references.schema.json#/definitions/externalReferences"
        }
      },
      "required": ["id", "title", "description"],
      "if": {
        "not": { "properties": { "deprecated": { "const": true } }, "required": ["deprecated"] }
      },
      "then": {
        "required": ["identificationQuestions"]
      },
      "additionalProperties": false
    }
  }
}
